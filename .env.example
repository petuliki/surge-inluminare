# === RunPod Workspace ===
WORKSPACE_DIR=/workspace

# === vLLM (Port 8000) ===
VLLM_MODEL=mlabonne/Qwen3-14B-abliterated
VLLM_QUANTIZATION=awq_marlin
VLLM_GPU_MEMORY_UTILIZATION=0.50
VLLM_MAX_MODEL_LEN=4096
VLLM_HOST=127.0.0.1
VLLM_PORT=8000

# === STT - faster-whisper (Port 8002) ===
STT_MODEL=large-v3-turbo
STT_LANGUAGE=de
STT_DEVICE=cuda
STT_COMPUTE_TYPE=float16
STT_HOST=127.0.0.1
STT_PORT=8002

# === TTS - CosyVoice 2 (Port 8001) ===
TTS_MODEL_DIR=/workspace/models/cosyvoice
TTS_HOST=127.0.0.1
TTS_PORT=8001

# === Pipecat + FastAPI (Port 8888) ===
API_HOST=0.0.0.0
API_PORT=8888

# === Pipeline Settings ===
LLM_TEMPERATURE=0.75
LLM_MAX_TOKENS=300
MAX_HISTORY_TURNS=20
VAD_MIN_SILENCE_MS=300
